<!-- Launch File for running SVO on SubT bag -->
<launch>

  <!-- Use your new SubT calibration -->
  <arg name="calib_file" default="$(find svo_ros)/param/calib/subt.yaml"/>

  <!-- SVO node -->
  <node pkg="svo_ros" type="svo_node" name="svo" clear_params="true" output="screen" args="--v=0">

    <!-- SubT camera topic -->
    <param name="cam0_topic" value="/cmu_rc7/camera_1/image_raw" type="str"/>

    <!-- SubT IMU topic -->
    <param name="imu_topic" value="/cmu_rc7/imu/data" type="str"/>

    <!-- Calibration file -->
    <param name="calib_file" value="$(arg calib_file)"/>

    <!-- Parameters -->
    <rosparam file="$(find svo_ros)/param/global_map.yaml"/>

    <!-- Loop closure -->
    <param name="runlc" value="true"/>

  </node>
  <node name="vis" pkg="rviz" type="rviz" args=" -d $(find svo_ros)/rviz_config_gm.rviz" />
</launch>